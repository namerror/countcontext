{
  "manifest_version": 3,
  "name": "ChatGPT Context Counter",
  "version": "0.9.3",
  "description": "Estimates ChatGPT conversation context usage from visible chat history with an in-page overlay.",
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": [
        "config.js",
        "content/namespace.js",
        "vendor/gpt-tokenizer/o200k_base.js",
        "vendor/gpt-tokenizer/cl100k_base.js",
        "tokenizers/ccx-tokenizer.js",
        "estimators/registry.js",
        "estimators/fast.js",
        "estimators/precise.js",
        "content/ui/overlay-drag.js",
        "content/ui/overlay-view.js",
        "content/core/page-context.js",
        "content/core/estimate-engine.js",
        "content/core/runtime-observers.js",
        "content.js"
      ],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "128": "icons/icon_128.png"
  }
}

{
  "manifest_version": 3,
  "name": "ChatGPT Context Counter",
  "version": "0.1.0",
  "description": "Estimates ChatGPT conversation context usage with an in-page overlay.",
  "permissions": ["storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://*.chatgpt.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
